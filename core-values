/* ── GHL NUKE ── */
(function(){
  function nuke(){
    var el=document.getElementById('cv');if(!el)return;
    var cur=el.parentElement;
    while(cur&&cur!==document.body){
      cur.style.setProperty('padding-top','0','important');
      cur.style.setProperty('padding-bottom','0','important');
      cur.style.setProperty('margin-top','0','important');
      cur.style.setProperty('margin-bottom','0','important');
      cur.style.setProperty('min-height','unset','important');
      cur=cur.parentElement;
    }
    ['[data-page-element="Section/V1"]','[data-page-element="Section/V2"]','[data-page-element="Row/V1"]','.page-section','.section-box'].forEach(function(s){
      document.querySelectorAll(s).forEach(function(n){
        if(n.contains(el)){
          n.style.setProperty('padding-top','0','important');
          n.style.setProperty('padding-bottom','0','important');
          n.style.setProperty('margin-top','0','important');
          n.style.setProperty('margin-bottom','0','important');
          n.style.setProperty('min-height','unset','important');
        }
      });
    });
  }
  nuke();
  window.addEventListener('load',function(){setTimeout(nuke,100);setTimeout(nuke,500);});
})();

/* ── NAV ── */
(function(){
  var nav=document.getElementById('cv-nav');
  var burger=document.getElementById('cv-burger');
  var drawer=document.getElementById('cv-drawer');
  if(!nav)return;
  function onScroll(){nav.classList.toggle('scrolled',window.scrollY>10);}
  window.addEventListener('scroll',onScroll,{passive:true});
  onScroll();
  var items=Array.from(nav.querySelectorAll('.gi[data-drop]'));
  items.forEach(function(item){
    var t=item.querySelector('.gtr');if(!t)return;
    t.addEventListener('click',function(e){
      e.stopPropagation();
      var isOpen=item.classList.contains('open');
      items.forEach(function(i){i.classList.remove('open');var tr=i.querySelector('.gtr');if(tr)tr.setAttribute('aria-expanded','false');});
      if(!isOpen){item.classList.add('open');t.setAttribute('aria-expanded','true');}
    });
  });
  document.addEventListener('click',function(){items.forEach(function(i){i.classList.remove('open');});});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){items.forEach(function(i){i.classList.remove('open');});nav.classList.remove('mob-open');}});
  if(burger&&drawer){
    burger.addEventListener('click',function(e){e.stopPropagation();nav.classList.toggle('mob-open');});
    Array.from(drawer.querySelectorAll('.cv-ms[data-mob]')).forEach(function(sec){
      var btn=sec.querySelector('.cv-mt');if(!btn)return;
      btn.addEventListener('click',function(){
        var wasOpen=sec.classList.contains('open');
        Array.from(drawer.querySelectorAll('.cv-ms')).forEach(function(s){s.classList.remove('open');});
        if(!wasOpen)sec.classList.add('open');
      });
    });
    drawer.querySelectorAll('a').forEach(function(a){a.addEventListener('click',function(){nav.classList.remove('mob-open');});});
  }
})();

/* ── SCROLL REVEAL ── */
(function(){
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target);}});
  },{threshold:0.06});
  document.querySelectorAll('#cv .rv').forEach(function(el){obs.observe(el);});
})();
</script>
