<style>
/* ── TOKENS & RESET ── */
#cv *,#cv *::before,#cv *::after{box-sizing:border-box;margin:0;padding:0;}
#cv{
  --black:#06070d;--white:#fff;--off:#f6f7f4;
  --ink:#0b1220;--muted:rgba(11,18,32,.72);--muted2:rgba(11,18,32,.45);
  --border:rgba(11,18,32,.10);--border-d:rgba(255,255,255,.08);
  --gold:#e7ff6e;--ease:cubic-bezier(.16,1,.3,1);
  font-family:-apple-system,'Segoe UI',Helvetica,Arial,sans-serif;
  -webkit-font-smoothing:antialiased;overflow-x:hidden;
}

/* ── NAV ── */
#cv-nav *,#cv-nav *::before,#cv-nav *::after{box-sizing:border-box;margin:0;padding:0;}
#cv-nav{position:fixed!important;top:0!important;left:0!important;right:0!important;z-index:1000!important;height:72px!important;font-family:-apple-system,'Segoe UI',Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;transition:background .3s,box-shadow .3s;}
#cv-nav.scrolled{background:rgba(6,7,13,.96)!important;backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);box-shadow:0 1px 0 rgba(255,255,255,.06);}
#cv-nav .ni{max-width:1320px!important;margin:0 auto!important;height:72px!important;display:flex!important;align-items:center!important;justify-content:space-between!important;padding:0 40px!important;gap:8px;}
#cv-nav .logo{display:flex!important;flex-direction:column!important;text-decoration:none;line-height:1.15;flex-shrink:0;}
#cv-nav .logo-n{font-size:16px;font-weight:800;color:#fff;letter-spacing:-.01em;}
#cv-nav .logo-t{font-size:9px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:#e7ff6e;}
#cv-nav .gm{display:flex!important;align-items:center!important;gap:0;list-style:none;flex:1;justify-content:center;}
#cv-nav .gi{position:relative;}
#cv-nav .gl,.gtr{display:inline-flex;align-items:center;gap:4px;padding:8px 13px;font-size:13px;font-weight:500;color:rgba(255,255,255,.72);text-decoration:none;border-radius:999px;border:none;background:none;cursor:pointer;white-space:nowrap;transition:color .18s,background .18s;font-family:inherit;letter-spacing:.01em;line-height:1;}
#cv-nav .gl:hover,.gtr:hover,#cv-nav .gi.open .gtr{color:#fff;background:rgba(255,255,255,.09);}
#cv-nav .gl.active{color:#fff;background:rgba(255,255,255,.1);}
#cv-nav .gc{width:12px;height:12px;opacity:.55;transition:transform .2s,opacity .2s;flex-shrink:0;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
#cv-nav .gi.open .gc{transform:rotate(180deg);opacity:1;}
#cv-nav .gd{position:absolute;top:calc(100% + 10px);left:50%;transform:translateX(-50%) translateY(-6px);min-width:220px;background:rgba(10,11,18,.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid rgba(255,255,255,.09);border-radius:16px;padding:8px;box-shadow:0 24px 60px rgba(0,0,0,.55);opacity:0;visibility:hidden;transition:opacity .2s,transform .2s,visibility .2s;pointer-events:none;}
#cv-nav .gi.open .gd{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0);pointer-events:all;}
#cv-nav .gd::before{content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);width:12px;height:6px;background:rgba(255,255,255,.09);clip-path:polygon(50% 0%,0% 100%,100% 100%);}
#cv-nav .gsl{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;transition:background .15s;}
#cv-nav .gsl:hover{background:rgba(255,255,255,.07);}
#cv-nav .gsi{width:30px;height:30px;border-radius:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.08);display:grid;place-items:center;flex-shrink:0;margin-top:1px;}
#cv-nav .gsi svg{width:14px;height:14px;stroke:rgba(255,255,255,.5);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
#cv-nav .gsn{font-size:13px;font-weight:600;color:rgba(255,255,255,.88);display:block;margin-bottom:2px;letter-spacing:-.01em;}
#cv-nav .gsd{font-size:11px;color:rgba(255,255,255,.38);line-height:1.4;display:block;}
#cv-nav .gdiv{height:1px;background:rgba(255,255,255,.07);margin:6px 0;}
#cv-nav .gcta{display:inline-flex!important;align-items:center;gap:6px;padding:9px 20px!important;border-radius:999px;background:#e7ff6e!important;color:#06070d!important;font-size:13px;font-weight:700;text-decoration:none;white-space:nowrap;flex-shrink:0;transition:background .18s,transform .18s;}
#cv-nav .gcta:hover{background:#f2ff8c!important;transform:translateY(-1px);}
#cv-nav .gb{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px;background:none;border:none;flex-shrink:0;}
#cv-nav .gb span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all .25s;}
#cv-nav.mob-open .gb span:nth-child(1){transform:translateY(7px) rotate(45deg);}
#cv-nav.mob-open .gb span:nth-child(2){opacity:0;}
#cv-nav.mob-open .gb span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
.cv-drawer{display:none;position:fixed;top:72px;left:0;right:0;background:rgba(6,7,13,.98);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.07);z-index:999;padding:0 0 24px;max-height:calc(100vh - 72px);overflow-y:auto;}
#cv-nav.mob-open .cv-drawer{display:block;}
.cv-ms{border-bottom:1px solid rgba(255,255,255,.06);}
.cv-mt{display:flex;align-items:center;justify-content:space-between;padding:14px 28px!important;font-size:14px;font-weight:600;color:rgba(255,255,255,.8);text-decoration:none;cursor:pointer;background:none;border:none;width:100%;text-align:left;font-family:inherit;}
.cv-mch{width:14px;height:14px;opacity:.4;transition:transform .2s;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}
.cv-ms.open .cv-mch{transform:rotate(180deg);opacity:.8;}
.cv-mch-wrap{display:none;padding:0 0 8px;}
.cv-ms.open .cv-mch-wrap{display:block;}
.cv-mc{display:block;padding:10px 28px 10px 40px!important;font-size:13px;color:rgba(255,255,255,.55);text-decoration:none;transition:color .18s;}
.cv-mc:hover{color:#fff;}
.cv-mcta{margin:20px 28px 0!important;display:block;text-align:center;padding:13px!important;background:#e7ff6e!important;color:#06070d!important;font-weight:700;font-size:14px;border-radius:999px;text-decoration:none;}
@media(max-width:1024px){
  #cv-nav .gm{display:none!important;}
  #cv-nav .gcta{display:none!important;}
  #cv-nav .gb{display:flex!important;}
  #cv-nav .ni{padding:0 20px!important;}
}

/* ── HERO ── */
#cv-hero{background:#06070d!important;padding:152px 40px 96px!important;position:relative;overflow:hidden;text-align:center;}
#cv-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 65% 55% at 50% 40%,rgba(231,255,110,.05) 0%,transparent 70%);pointer-events:none;}
#cv-hero::after{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);background-size:80px 80px;pointer-events:none;}
#cv-hero .ey{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:22px!important;position:relative;z-index:1;}
#cv-hero .ed{width:5px;height:5px;border-radius:50%;background:#e7ff6e;box-shadow:0 0 8px rgba(231,255,110,.8);}
#cv-hero h1{font-size:clamp(38px,5.5vw,76px)!important;font-weight:800!important;line-height:.97!important;letter-spacing:-.03em!important;color:#fff!important;margin-bottom:22px!important;position:relative;z-index:1;}
#cv-hero h1 em{font-style:italic;color:#e7ff6e;}
#cv-hero .hs{font-size:clamp(16px,2vw,19px)!important;font-weight:300!important;line-height:1.78!important;color:rgba(255,255,255,.58)!important;max-width:620px!important;margin:0 auto 52px!important;position:relative;z-index:1;}
/* Value summary pills */
#cv-hero .val-pills{display:flex!important;flex-wrap:wrap!important;gap:10px!important;justify-content:center!important;position:relative;z-index:1;}
#cv-hero .vp{display:inline-flex;align-items:center;gap:10px;padding:11px 20px!important;border:1px solid rgba(255,255,255,.1)!important;border-radius:999px;background:rgba(255,255,255,.04)!important;font-size:13px;font-weight:600;color:rgba(255,255,255,.65);white-space:nowrap;letter-spacing:.01em;}
#cv-hero .vp-dot{width:5px;height:5px;border-radius:50%;background:#e7ff6e;flex-shrink:0;}

/* ── SHARED ── */
.cv-light{background:linear-gradient(180deg,#f6f7f4,#fff)!important;border-top:1px solid rgba(11,18,32,.10)!important;border-bottom:1px solid rgba(11,18,32,.10)!important;padding:88px 0!important;}
.cv-dark{background:linear-gradient(180deg,rgba(11,18,32,.96),rgba(11,18,32,.92))!important;border-top:1px solid rgba(255,255,255,.08)!important;border-bottom:1px solid rgba(255,255,255,.08)!important;padding:88px 0!important;}
.cv-wrap{max-width:1180px!important;margin:0 auto!important;padding:0 40px!important;}
.cv-brow{display:flex!important;align-items:center!important;gap:10px;font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;margin-bottom:18px!important;}
.cv-bdot{width:8px;height:8px;border-radius:99px;background:#e7ff6e;box-shadow:0 0 0 3px rgba(231,255,110,.25);flex-shrink:0;}
.cv-brow-l{color:rgba(11,18,32,.6);}
.cv-brow-d{color:rgba(255,255,255,.52);}
.cv-h2{font-size:clamp(28px,3.6vw,50px)!important;font-weight:800!important;line-height:1.0!important;letter-spacing:-.025em!important;margin-bottom:18px!important;}
.cv-h2-l{color:#0b1220!important;}
.cv-h2-d{color:#fff!important;}
.cv-h2 em{font-style:italic;}
.cv-h2-l em{color:rgba(11,18,32,.42);border-bottom:3px solid #e7ff6e;padding-bottom:2px;}
.cv-h2-d em{color:#e7ff6e;}
.cv-body{font-size:15px!important;font-weight:300!important;line-height:1.82!important;margin-bottom:16px!important;}
.cv-body-l{color:rgba(11,18,32,.72)!important;}
.cv-body-d{color:rgba(255,255,255,.62)!important;}

/* ── OVERVIEW (light, intro + 5 teaser cards) ── */
#cv-overview .ov-intro{display:grid!important;grid-template-columns:1fr 1fr!important;gap:72px!important;align-items:center!important;margin-bottom:64px!important;}
#cv-overview .ov-cards{display:grid!important;grid-template-columns:repeat(5,1fr)!important;gap:1px!important;background:rgba(11,18,32,.1)!important;border:1px solid rgba(11,18,32,.1)!important;}
#cv-overview .ovc{background:#fff!important;padding:28px 20px!important;position:relative;transition:background .2s;}
#cv-overview .ovc:hover{background:var(--off)!important;}
#cv-overview .ovc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:transparent;transition:background .25s;}
#cv-overview .ovc:hover::before{background:linear-gradient(90deg,#e7ff6e,rgba(231,255,110,.15));}
#cv-overview .ovc-icon{width:40px;height:40px;border-radius:10px;background:rgba(231,255,110,.1);border:1px solid rgba(231,255,110,.22);display:grid;place-items:center;margin-bottom:16px!important;}
#cv-overview .ovc-icon svg{width:18px;height:18px;stroke:#0b1220;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
#cv-overview .ovc-n{font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(11,18,32,.32);margin-bottom:8px!important;}
#cv-overview .ovc h3{font-size:15px;font-weight:700;color:#0b1220;letter-spacing:-.01em;}

/* ── VALUES DEEP DIVE (alternating light/dark) ── */
.cv-value-l{background:linear-gradient(180deg,#f6f7f4,#fff)!important;border-top:1px solid rgba(11,18,32,.10)!important;border-bottom:1px solid rgba(11,18,32,.10)!important;padding:80px 0!important;}
.cv-value-d{background:linear-gradient(180deg,rgba(11,18,32,.96),rgba(11,18,32,.92))!important;border-top:1px solid rgba(255,255,255,.08)!important;border-bottom:1px solid rgba(255,255,255,.08)!important;padding:80px 0!important;}
.cv-val{display:grid!important;grid-template-columns:1fr 1fr!important;gap:72px!important;align-items:start!important;}
.cv-val.flip{direction:rtl;}
.cv-val.flip>*{direction:ltr;}
.cv-val-num{font-size:clamp(80px,10vw,140px);font-weight:800;line-height:.85;letter-spacing:-.04em;color:rgba(11,18,32,.07);margin-bottom:4px!important;}
.cv-val-num-d{color:rgba(255,255,255,.06);}
.cv-val-tag{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(11,18,32,.38);margin-bottom:14px!important;}
.cv-val-tag-d{color:rgba(255,255,255,.35);}
.cv-val-title{font-size:clamp(26px,3vw,38px)!important;font-weight:800!important;letter-spacing:-.025em!important;line-height:1.1!important;color:#0b1220!important;margin-bottom:18px!important;}
.cv-val-title-d{color:#fff!important;}
.cv-val-body{font-size:15px!important;font-weight:300!important;line-height:1.82!important;color:rgba(11,18,32,.7)!important;margin-bottom:20px!important;}
.cv-val-body-d{color:rgba(255,255,255,.6)!important;}
.cv-val-list{list-style:none;display:flex;flex-direction:column;gap:10px;}
.cv-val-list li{font-size:14px;color:rgba(11,18,32,.65);display:flex;align-items:flex-start;gap:10px;line-height:1.6;}
.cv-val-list-d li{color:rgba(255,255,255,.55);}
.cv-val-list li::before{content:'';width:4px;height:4px;border-radius:50%;background:#e7ff6e;flex-shrink:0;margin-top:8px;}
.cv-val-panel{background:#fff!important;border:1px solid rgba(11,18,32,.1)!important;border-radius:20px!important;padding:36px!important;box-shadow:0 18px 45px rgba(11,18,32,.06)!important;position:relative;}
.cv-val-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#e7ff6e,rgba(231,255,110,.12));border-radius:20px 20px 0 0;}
.cv-val-panel-d{background:rgba(255,255,255,.05)!important;border:1px solid rgba(255,255,255,.1)!important;border-radius:20px!important;padding:36px!important;position:relative;}
.cv-val-panel-d::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#e7ff6e,rgba(231,255,110,.12));border-radius:20px 20px 0 0;}
.cv-val-panel-label{font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(11,18,32,.35);margin-bottom:14px!important;}
.cv-val-panel-label-d{color:rgba(255,255,255,.35);}
.cv-val-panel-q{font-size:clamp(15px,1.8vw,18px)!important;font-style:italic;font-weight:300;color:#0b1220!important;line-height:1.65!important;}
.cv-val-panel-q-d{color:rgba(255,255,255,.75)!important;}
.cv-val-icon{width:52px;height:52px;border-radius:14px;background:rgba(231,255,110,.1);border:1px solid rgba(231,255,110,.22);display:grid;place-items:center;margin-bottom:20px!important;}
.cv-val-icon svg{width:24px;height:24px;stroke:#0b1220;fill:none;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round;}
.cv-val-icon-d{background:rgba(231,255,110,.08)!important;border:1px solid rgba(231,255,110,.18)!important;}
.cv-val-icon-d svg{stroke:rgba(255,255,255,.7);}

/* ── IN PRACTICE (dark, table-style) ── */
#cv-practice .pr-table{margin-top:48px!important;border:1px solid rgba(255,255,255,.07)!important;border-radius:16px!important;overflow:hidden;}
#cv-practice .pr-head{display:grid!important;grid-template-columns:180px 1fr 1fr!important;background:rgba(255,255,255,.04)!important;border-bottom:1px solid rgba(255,255,255,.07)!important;}
#cv-practice .pr-head-cell{padding:14px 20px!important;font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.38);}
#cv-practice .pr-row{display:grid!important;grid-template-columns:180px 1fr 1fr!important;border-bottom:1px solid rgba(255,255,255,.06)!important;}
#cv-practice .pr-row:last-child{border-bottom:none!important;}
#cv-practice .pr-row:hover{background:rgba(255,255,255,.03)!important;}
#cv-practice .pr-cell{padding:20px!important;font-size:13.5px;color:rgba(255,255,255,.55);line-height:1.65;border-right:1px solid rgba(255,255,255,.06)!important;}
#cv-practice .pr-cell:last-child{border-right:none!important;}
#cv-practice .pr-cell-val{font-size:13px;font-weight:700;color:#fff;border-right:1px solid rgba(255,255,255,.06)!important;display:flex;align-items:center;gap:8px;}
#cv-practice .pr-cell-dot{width:6px;height:6px;border-radius:50%;background:#e7ff6e;flex-shrink:0;}

/* ── CTA ── */
#cv-cta{background:#06070d!important;padding:96px 40px!important;text-align:center;border-top:1px solid rgba(255,255,255,.08)!important;position:relative;overflow:hidden;}
#cv-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 50% at 50% 50%,rgba(231,255,110,.06) 0%,transparent 70%);}
#cv-cta .ci{position:relative;z-index:1;max-width:600px;margin:0 auto!important;}
#cv-cta h2{font-size:clamp(30px,4vw,52px)!important;font-weight:800!important;letter-spacing:-.025em!important;line-height:1.05!important;color:#fff!important;margin-bottom:16px!important;}
#cv-cta h2 em{color:#e7ff6e;font-style:italic;}
#cv-cta p{font-size:17px!important;font-weight:300!important;color:rgba(255,255,255,.5)!important;line-height:1.8!important;margin-bottom:38px!important;}
#cv-cta .cbtns{display:flex!important;gap:14px!important;justify-content:center!important;flex-wrap:wrap!important;}
.cv-btn-gold{display:inline-flex;align-items:center;gap:7px;padding:13px 26px!important;border-radius:999px;background:#e7ff6e!important;color:#06070d!important;font-size:14px;font-weight:700;text-decoration:none;border:none;cursor:pointer;transition:all .2s;font-family:inherit;}
.cv-btn-gold:hover{background:#f2ff8c!important;transform:translateY(-2px);box-shadow:0 10px 28px rgba(231,255,110,.38);}
.cv-btn-dk{display:inline-flex;align-items:center;gap:7px;padding:12px 24px!important;border-radius:999px;background:rgba(255,255,255,.08)!important;color:rgba(255,255,255,.75)!important;font-size:14px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.15)!important;cursor:pointer;transition:all .2s;font-family:inherit;}
.cv-btn-dk:hover{background:rgba(255,255,255,.14)!important;color:#fff!important;}

/* ── FOOTER ── */
#cv-footer{background:#06070d!important;color:rgba(255,255,255,.5);border-top:1px solid rgba(255,255,255,.07)!important;font-family:inherit;}
#cv-footer .ft-top{max-width:1280px!important;margin:0 auto!important;padding:72px 40px 48px!important;display:grid!important;grid-template-columns:1.8fr 1fr 1fr 1fr 1fr!important;gap:48px!important;}
#cv-footer .ft-ln{font-size:20px;font-weight:800;color:#fff;letter-spacing:-.01em;margin-bottom:4px!important;}
#cv-footer .ft-lt{font-size:9px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:#e7ff6e;margin-bottom:18px!important;}
#cv-footer .ft-tl{font-size:13px;line-height:1.75;color:rgba(255,255,255,.38);max-width:260px;margin-bottom:24px!important;}
#cv-footer .ft-soc{display:flex!important;gap:10px!important;}
#cv-footer .ft-soc a{width:36px;height:36px;border-radius:50%;border:1px solid rgba(255,255,255,.12)!important;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);text-decoration:none;transition:border-color .18s,color .18s;}
#cv-footer .ft-soc a:hover{border-color:#e7ff6e!important;color:#e7ff6e!important;}
#cv-footer .ft-col h4{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:#fff;margin-bottom:18px!important;}
#cv-footer .ft-col ul{list-style:none;display:flex!important;flex-direction:column!important;gap:10px!important;padding:0;}
#cv-footer .ft-col ul a{font-size:13px;color:rgba(255,255,255,.42);text-decoration:none;transition:color .18s;}
#cv-footer .ft-col ul a:hover{color:#fff;}
#cv-footer .ft-bot{border-top:1px solid rgba(255,255,255,.07)!important;max-width:1280px!important;margin:0 auto!important;padding:24px 40px!important;display:flex!important;align-items:center!important;justify-content:space-between!important;flex-wrap:wrap!important;gap:12px!important;}
